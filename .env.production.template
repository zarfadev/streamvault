# ─────────────────────────────────────────────────────────────────────────────
# StreamVault — Plantilla de Variables de Entorno para Producción
#
# Copia este archivo a .env y rellena los valores:
#   cp .env.production.template .env
#
# NUNCA subas .env al repositorio — está en .gitignore y .dockerignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL pública de la aplicación (sin trailing slash)
APP_URL=https://tu-dominio.com

# Orígenes permitidos por CORS (separados por coma)
ALLOWED_ORIGINS=https://tu-dominio.com

# Confiar en el proxy reverso para leer la IP real del cliente.
# 1 = un proxy (Nginx, ALB, Cloudflare). Requerido cuando corres detrás de Nginx.
TRUST_PROXY=1

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
# Neon:     postgres://user:pass@host.neon.tech/dbname?sslmode=require
# Supabase: postgres://postgres:pass@db.xxx.supabase.co:5432/postgres
# RDS:      postgres://user:pass@xxx.rds.amazonaws.com:5432/dbname
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Conexiones PG por proceso. En PM2 cluster: total = DB_POOL_MAX × instancias API.
# Con Neon/Supabase free (100 conexiones) y 4 instancias API → DB_POOL_MAX=10.
DB_POOL_MAX=10

# Habilitar SSL si el provider lo requiere fuera de la URL de conexión
# DATABASE_SSL=true

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash:     rediss://default:token@host.upstash.io:6379  (rediss = TLS)
# ElastiCache: redis://host.cache.amazonaws.com:6379
# Railway:     redis://default:pass@host.railway.app:6379
REDIS_URL=rediss://default:token@host:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# OBLIGATORIO: mínimo 64 caracteres, distintos entre sí.
# Generar: node -e "require('crypto').randomBytes(32).toString('hex')" | pbcopy
JWT_SECRET=cambia-esto-a-64-caracteres-aleatorios
JWT_REFRESH_SECRET=cambia-esto-a-otros-64-caracteres-distintos

# ── S3 / CloudFront ───────────────────────────────────────────────────────────
S3_BUCKET=nombre-de-tu-bucket
AWS_REGION=us-east-1

# Prefijo de carpeta dentro del bucket (sin slash inicial ni final)
S3_KEY_PREFIX=media

# URL base del CDN (CloudFront o S3 website endpoint, sin trailing slash)
CLOUDFRONT_BASE_URL=https://xxxxxxxx.cloudfront.net

# ID de la distribución CloudFront — necesario para invalidar caché al borrar videos.
# Formato: E seguido de ~14 caracteres  (ej: E2QDBXXXXXXXX)
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXX

# Borrar archivos locales tras subirlos a S3 (necesario en multi-servidor)
DELETE_LOCAL_AFTER_S3=1

# Credenciales AWS — solo si el servidor NO tiene IAM role asignado.
# En EC2 con IAM role no hace falta — la SDK las obtiene automáticamente.
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Sin configurar: los emails se loguean en consola (no se envían).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=tu-api-key-de-sendgrid
SMTP_FROM=noreply@tu-dominio.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email que se promoverá a super_admin en el primer arranque
SUPER_ADMIN_EMAIL=tu@email.com

# API key de acceso al panel de administración (alternativa a JWT super_admin)
# Generar: openssl rand -hex 32
ADMIN_API_KEY=

# ── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── reCAPTCHA v3 (opcional) ───────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── AWS Bedrock (AI — resúmenes y análisis de contenido) ─────────────────────
# Solo para plan Pro/Enterprise. Requiere permiso IAM: bedrock:InvokeModel.
BEDROCK_MODEL_ID=claude-haiku-4-5-20251001

# ── Workers ───────────────────────────────────────────────────────────────────
# Jobs FFmpeg en paralelo por instancia de worker (ajustar según CPUs del servidor)
WORKER_CONCURRENCY=3

# Jobs Whisper en paralelo por instancia de worker
TRANSCRIPTION_CONCURRENCY=2

# Alerta cuando hay más de N jobs esperando en la cola de transcoding
QUEUE_ALERT_THRESHOLD=20

# ── DB — timeouts ─────────────────────────────────────────────────────────────
DB_CONNECT_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000

# Reintentos de conexión al arrancar (útil en Docker cuando la DB tarda)
DB_CONNECT_RETRIES=5
DB_CONNECT_DELAY_MS=3000
