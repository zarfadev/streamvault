# ─── Environment Variables ───────────────────────────────────────────────────
# Copy to .env and fill in your values.
# All variables marked REQUIRED must be set before starting the server.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (production example below).
# Leave empty in development to allow all origins.
# Example: https://app.your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=

# ─── Database (REQUIRED) ─────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local:    postgres://user:password@localhost:5432/mydb
# Supabase: postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres
# RDS:      postgres://user:password@[host]:5432/mydb
DATABASE_URL=postgres://postgres:password@localhost:5432/mydb

# Set to "true" when connecting to RDS / Supabase / any managed PG with SSL.
DATABASE_SSL=false

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-random-64-chars
JWT_REFRESH_SECRET=change-me-to-different-random-64-chars

# Optional: static API key for admin automation scripts.
ADMIN_API_KEY=your-admin-api-key

# ─── Google reCAPTCHA v3 (optional — validation skipped when not set) ─────────
# Get keys at: https://www.google.com/recaptcha/admin/create (type: v3)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Optional: email to auto-promote to super_admin on first startup.
# Set this to your admin email BEFORE the first run to avoid the warning:
#   "⚠ SUPER_ADMIN_EMAIL not set — no super admin will be auto-promoted"
# After the first run the role is stored in the DB and this can be left empty.
# Example: SUPER_ADMIN_EMAIL=admin@yourcompany.com
SUPER_ADMIN_EMAIL=

# ─── Redis + Bull Queue (REQUIRED for worker) ─────────────────────────────────
# Required to run the transcoder worker (node worker.js).
# Local:     redis://localhost:6379
# Upstash:   rediss://:[password]@[host]:6379
# ElastiCache: redis://[host]:6379
REDIS_URL=redis://localhost:6379

# Number of parallel transcoding jobs the worker will process (default: 2).
WORKER_CONCURRENCY=2

# ─── AWS S3 + CloudFront (recommended in production) ─────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=your-media-bucket
S3_KEY_PREFIX=media

# CloudFront distribution URL (no trailing slash).
# If not set, falls back to direct S3 URL.
# Example: https://d1234abcd.cloudfront.net
CLOUDFRONT_BASE_URL=

# CDN base URL for serving static assets (CSS, JS, images).
# When set, the Content-Security-Policy allows this origin for script-src/style-src.
# Use the same value as CLOUDFRONT_BASE_URL if you serve both HLS and static assets.
# Example: https://d1234abcd.cloudfront.net
CDN_BASE_URL=

# Set to "1" to delete local HLS files after a successful S3 upload.
DELETE_LOCAL_AFTER_S3=0

# ─── Email (Nodemailer SMTP) ──────────────────────────────────────────────────
# Leave empty to use console.log fallback in development.
# Brevo (recommended): smtp-relay.brevo.com:587
# Gmail: smtp.gmail.com:587
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-brevo-api-key
SMTP_FROM=noreply@yourdomain.com

# ─── Payment Gateways ─────────────────────────────────────────────────────────
# La plataforma soporta 3 proveedores de pago (multi-gateway):
# - Stripe: Tarjetas de crédito/débito globalmente
# - PayPal: PayPal + tarjetas + PSE (ideal para Colombia y LATAM)
# - Binance Pay: Criptomonedas (USDT, BTC, BUSD)

# ══════════════════════════════════════════════════════════════════════════════
# STRIPE (Global Card Payments)
# ══════════════════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_...
# CRITICAL: Set webhook secret for signature validation (get from Stripe Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# ══════════════════════════════════════════════════════════════════════════════
# PAYPAL (LATAM Friendly - Tarjetas, PayPal Balance, PSE)
# ══════════════════════════════════════════════════════════════════════════════
# Get credentials at: https://developer.paypal.com/
# Create Products and Subscription Plans in PayPal Dashboard
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# Webhook ID (get from PayPal Dashboard after creating webhook)
PAYPAL_WEBHOOK_ID=

# Plan IDs (create in PayPal Dashboard: Products & Plans)
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_ENTERPRISE=

# ══════════════════════════════════════════════════════════════════════════════
# BINANCE PAY (Cryptocurrency Payments - USDT, BTC, BUSD)
# ══════════════════════════════════════════════════════════════════════════════
# Get credentials at: https://merchant.binance.com/
# Requires KYC verification
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_MERCHANT_ID=
BINANCE_MODE=sandbox

# Prices in USD (converted to USDT 1:1 for stability)
BINANCE_PRICE_STARTER=9.99
BINANCE_PRICE_PRO=29.99
BINANCE_PRICE_ENTERPRISE=99.99

# ─── Amazon Bedrock (AI Content Intelligence — Pro/Enterprise) ───────────────
# Requires AWS_REGION to be set (same credentials as S3 via IAM role or keys).
# IAM permission needed: bedrock:InvokeModel on the model ARN.
# Default model: claude-haiku-4-5-20251001 (Claude Haiku 4.5 — fast + cheap)
# Override with a different Claude model if needed:
# BEDROCK_MODEL_ID=claude-sonnet-4-5-20251001
BEDROCK_MODEL_ID=claude-haiku-4-5-20251001

# ─── Video Security ───────────────────────────────────────────────────────────
# Set to "true" to require signed tokens for ALL HLS video requests globally.
# When false (default), tokens are only enforced for workspaces with an
# embedAllowedDomains list configured.
REQUIRE_VIDEO_TOKENS=false

# ─── Admin Panel Protection ───────────────────────────────────────────────────
# CRITICAL: Set this to protect /admin panel access.
# Generate with: node -e "const crypto = require('crypto'); console.log('sv_admin_' + crypto.randomBytes(32).toString('hex'));"
# Copy this value to your .env file:
ADMIN_SECRET=sv_admin_b4dcb05267329198264d4e84072cb9d07bae7687863bdf2c72cb7ef9be244c90

# ─── Development / Seeding ────────────────────────────────────────────────────
# Set to "1" to seed the demo account even in production (not recommended).
SEED_DEMO_USER=0
